<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Follow_Up_Status__c</fullName>
    <description>It is used to find the follow up status</description>
    <formula>AND(Follow_up_Date__c &lt; TODAY(),
 NOT(OR(ISPICKVAL( Appointment_Status__c , &quot;Completed&quot;) ,ISPICKVAL( Appointment_Status__c , &quot;Cancelled&quot; ))))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Follow-Up Status</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
