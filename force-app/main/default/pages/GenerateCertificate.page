<!--
* Purpose: This page is used to Generate Certificate using basic details of ceritification
* Created By: Nelson Samuel J
* Created On: 18-06-2026
-->
<apex:page controller="GenerateCertificateController" renderAs="{!strRenderMode}" docType="html-5.0">
    <html>

    <head>
        <style>
            @page{
                size: 11.69in 8.27in; 
                margin: 0mm;
            }
            body{
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            }
            .btn{
                background: none !important;
                background-image: none !important;
                background-color: #0051a7 !important;
                color: white !important;
                padding: 10px 20px !important;
                border: none !important;
                border-radius: 4px !important;
                font-weight: bold;
                cursor: pointer;
                margin-top: 15px;
            }
        </style>
    </head>

    <body>

        <!-- Get Data from User UI to generate Certificate  -->
        <apex:outputPanel rendered="{!ISBLANK(strRenderMode)}">
            <div style="text-align: center; padding: 20px;">
                <h1 style="margin: 0; font-size: x-large; font-weight: bolder;">Maayan Institution - Certificate Generator</h1>
                <p style="color: gray; font-size: 13.7px; margin: 0px; margin-top: 4px;">Enter the details below and click on Generate Certificate to download the PDF.</p>

                <div style="margin-top: 22px;">
                    <apex:form >
                        <table style="width: 100%; border-collapse: collapse; border: 1px solid #f1f1f1; border-radius: 5px;">
                            <tr>
                                <th colspan="3" style="background-color: aliceblue; padding: 10px; border: 1px solid #f2f2f2; font-size: small;">Certificate Details</th>
                            </tr>
                            <tr>
                                <td style=" padding: 20px; font-weight: 600; width: 12%; text-align: left;">Student Name</td>
                                <td style=" width: 1%;">:</td>
                                <td style="padding: 20px; width: 60%; text-align: left; padding-left: 0px;">
                                    <apex:inputText value="{!objCertData.StudentName}" style="width: 80%; padding: 6px; border: 1.5px solid #f2f2f2;" required="true"
                                    />
                                </td>
                            </tr>
                            <tr>
                                <td style=" padding: 20px; font-weight: 600; text-align: left; ">Course Name</td>
                                <td style="padding: 20px;">:</td>
                                <td style="padding: 20px; text-align: left; padding-left: 0px;">
                                    <apex:inputText value="{!objCertData.CourseName}" style="width: 80%; padding: 6px; border: 1.5px solid #f2f2f2;" required="true"
                                    />
                                </td>
                            </tr>
                            <tr>
                                <td style=" padding: 20px; font-weight: 600; text-align: left;">Batch Number</td>
                                <td style="padding: 20px;">:</td>
                                <td style="padding: 20px; text-align: left; padding-left: 0px;">
                                    <apex:inputText value="{!objCertData.BatchNumber}" style="width: 80%; padding: 6px; border: 1.5px solid #f2f2f2;" required="true"
                                    />
                                </td>
                            </tr>
                            <tr>
                                <td style=" padding: 20px; font-weight: 600; text-align: left;">Completion Date</td>
                                <td style="padding: 20px;">:</td>
                                <td style="padding: 20px; text-align: left; padding-left: 0px;">
                                    <apex:inputText value="{!objCertData.CompletionDate}" html-type="date" style="width: 80%; padding: 6px; border: 1.5px solid #f2f2f2;"
                                        required="true" />
                                </td>
                            </tr>
                            <tr>
                                <td style=" padding: 20px; font-weight: 600; vertical-align: top; text-align: left;">Trainer Name</td>
                                <td style="padding: 20px; vertical-align: top;">:</td>
                                <td style="padding: 20px; text-align: left; padding-left: 0px;">
                                    <apex:inputText value="{!objCertData.TrainerName}" style="width: 80%; padding: 6px; border: 1.5px solid #f2f2f2;" required="true"
                                    />
                                </td>
                            </tr>

                            <!-- Generate Certificate Button  -->
                            <tr>
                                <td colspan="3">
                                    <div style="text-align: center; padding: 20px 0px; border-top: 1px solid #f2f2f2;">
                                        <apex:commandButton action="{!generateCertificate}" value="Generate Certificate" styleClass="btn" style="background-color: #0051a7 !important;"
                                        />
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </apex:form>
                </div>
            </div>
        </apex:outputPanel>

        <!-- Pdf Design  -->
        <apex:outputPanel rendered="{!strRenderMode == 'pdf'}">
            <div style="font-family: 'Inter', -apple-system, sans-serif; padding: 40px; background: #ffffff; border: 16px solid #4285F4; min-height: 550px; position: relative; box-sizing: border-box;">

                <!-- Header with Colorful Design  -->
                <div style="text-align: center;">
                    <img src="{!$Resource.AWT_LOGO}" alt="Logo" height="100" width="200" />
                    <p style="margin: 5px 0 0 0; font-size: 11px; font-weight: 600; color:  #EA4335; letter-spacing: 0.25em; text-transform: uppercase;">
                        Google Institution
                    </p>
                    <h1 style="margin: 25px 0 0 0; font-size: 38px; font-weight: 700; color: #4285F4; font-family: 'Georgia', serif; letter-spacing: 0.02em;">
                        CERTIFICATE OF COMPLETION
                    </h1>
                    <div style="margin: 15px auto; width: 220px; text-align: center; position: relative;">
                        <div style="display: inline-block; width: 25%; border-top: 3px solid #4285F4; margin: 0; padding: 0;"></div>
                        <div style="display: inline-block; width: 25%; border-top: 3px solid #EA4335; margin: 0; padding: 0;"></div>
                        <div style="display: inline-block; width: 25%; border-top: 3px solid #FBBC05; margin: 0; padding: 0;"></div>
                        <div style="display: inline-block; width: 25%; border-top: 3px solid #34A853; margin: 0; padding: 0;"></div>
                        <span style="position: absolute; top: -6px; left: 50%; transform: translateX(-50%); background: #ffffff; padding: 0 8px; color: #FBBC05; font-size: 10px;">❖</span>
                    </div>
                </div>

                <div style="text-align: center; font-family: 'Inter', -apple-system, sans-serif; margin-top: 30px;">
                    <p style="font-family: 'Georgia', serif; font-style: italic; font-size: 16px; color: #5f6368; margin: 0 0 15px 0;">
                        This is to certify that
                    </p>
                    <h2 style="font-family: 'Georgia', serif; font-size: 36px; font-weight: 700; color: #000000; margin: 0 0 15px 0; letter-spacing: -0.01em;">
                        {!objCertData.StudentName}
                    </h2>

                    <p style="font-family: 'Georgia', serif; font-style: italic; font-size: 15px; color: #5f6368; margin: 0 0 15px 0;">
                        has successfully completed the course
                    </p>
                    <h3 style="font-family: 'Georgia', serif; font-size: 26px; font-weight: 700; color: #34A853; margin: 0 0 35px 0;">
                        {!objCertData.CourseName}
                    </h3>

                    <!-- Using Table segregate Header and Value  -->
                    <table style="width: 50%; margin: 0 auto; border-collapse: collapse; font-size: 15px; color: #202124; text-align: left;">
                        <tr>
                            <td style="padding: 8px 0; font-weight: 700; width: 45%; font-family: 'Inter', sans-serif;">Batch Number</td>
                            <td style="padding: 8px 0; width: 10%; text-align: center; color: #64748b;">:</td>
                            <td style="padding: 8px 0; width: 45%; font-weight: 500; font-family: 'Inter', sans-serif;">{!objCertData.BatchNumber}</td>
                        </tr>
                        <tr>
                            <td style="padding: 8px 0; font-weight: 700; font-family: 'Inter', sans-serif;">Completion Date</td>
                            <td style="padding: 8px 0; text-align: center; color: #64748b;">:</td>
                            <td style="padding: 8px 0; font-weight: 500; font-family: 'Inter', sans-serif;">
                                <apex:outputText value="{!formattedCompletionDate}">
                                </apex:outputText>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 8px 0; font-weight: 700; font-family: 'Inter', sans-serif;">Trainer Name</td>
                            <td style="padding: 8px 0; text-align: center; color: #64748b;">:</td>
                            <td style="padding: 8px 0; font-weight: 500; font-family: 'Inter', sans-serif;">{!objCertData.TrainerName}</td>
                        </tr>
                    </table>
                </div>

                <!-- To show sign and Date  -->
                <table style="width: 100%; margin-top: 60px; border-collapse: collapse;">
                    <tr>
                        <td style="width: 50%; text-align: left; vertical-align: bottom; padding-left: 20px;">
                            <div style="width: 200px; text-align: center;">
                                <img src="{!$Resource.GoogleOwnerSignature}" alt="Signature" height="60" style="display: block; margin: 0 auto; margin-left: 50px; object-fit: contain; mix-blend-mode: multiply;"
                                />
                                <div style="border-top: 1px solid #70757a; margin-top: 5px; padding-top: 5px;">
                                    <p style="margin: 0; font-size: 12px; font-weight: 600; color: #202124;">Authorized Signature</p>
                                </div>
                            </div>
                        </td>

                        <td style="width: 50%; text-align: right; vertical-align: bottom; padding-right: 20px;">
                            <div style="display: inline-block; text-align: center;">
                                <p style="margin: 0; font-size: 12px; color: #5f6368; font-weight: 500;">Certificate Generated On</p>

                                <p style="margin: 4px 0 0 0; font-size: 13px; font-weight: 700; color: #202124;">{!strToday}</p>
                            </div>
                        </td>
                    </tr>
                </table>
            </div>
        </apex:outputPanel>
    </body>

    </html>

</apex:page>